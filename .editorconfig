# ---------------------------------------------------------------------------
# omiiCARE_QA — EditorConfig (https://editorconfig.org)
# The single source of truth for whitespace/encoding across all editors & IDEs.
# ---------------------------------------------------------------------------
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
max_line_length = 120

# --- Java ---
[*.java]
indent_size = 4
ij_continuation_indent_size = 8

# --- Web / TS / JSON / YAML use 2 spaces ---
[*.{ts,tsx,js,jsx,json,yml,yaml,css,scss,html}]
indent_size = 2

# --- Markdown: keep trailing spaces (hard line breaks) ---
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# --- Maven / XML ---
[*.xml]
indent_size = 2

# --- Windows batch scripts ---
[*.{bat,cmd}]
end_of_line = crlf

# --- Makefiles require tabs ---
[Makefile]
indent_style = tab
