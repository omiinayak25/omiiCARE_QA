<?xml version="1.0" encoding="UTF-8"?>
<!--
  Structured logging for omiiCARE_QA backend.
  - Console pattern includes correlation/request/trace/span IDs (observability).
  - JSON appender (activated in docker/qa/stage/prod) for log aggregation.
  - Rolling file appender with size+time policy for local/file-based runs.
-->
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %5p [%X{correlationId:-},%X{requestId:-},%X{traceId:-},%X{spanId:-}] [%t] %-40.40logger{39} : %m%n"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/omiicare-qa-backend.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>logs/omiicare-qa-backend.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>2GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- Default (dev/local/test): human-readable console + rolling file. -->
    <springProfile name="dev,local,test">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>
    </springProfile>

    <!-- Containerized / higher environments: console only (collected by the platform). -->
    <springProfile name="docker,qa,stage,prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>
</configuration>
