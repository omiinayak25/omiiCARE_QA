<?xml version="1.0" encoding="UTF-8"?>
<!--
  OWASP Dependency-Check suppressions — omiiCARE_QA (Milestone 7)

  EDUCATIONAL / local-infra-only.

  Rules for every suppression:
    * Include <notes> with: justification, approver, and review/expiry date.
    * Scope precisely (sha1 / packageUrl / anchored filePath) — no broad globs.
    * Suppress a specific <cve> / <cpe> / <vulnerabilityName> — never "all".

  Schema: https://dependency-check.github.io/DependencyCheck/general/suppression.html
-->
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!--
      EXAMPLE (template — replace before use):
      Suppresses a false-positive CPE mismatch where Dependency-Check maps the
      H2 test/dev database to an unrelated product CVE. H2 is a dev/test-only
      runtime dependency in omiiCARE_QA (h2-console is dev-profile only) and is
      not shipped in the production runtime path.
    -->
    <suppress>
        <notes><![CDATA[
            FALSE POSITIVE: CPE mis-attribution example for the H2 dev/test
            database. H2 is used only in dev/test profiles (h2-console). Replace
            the packageUrl regex and CVE with the actual finding before relying
            on this entry.
            Justification: false-positive CPE match.
            Approved by: Security Engineer.
            Review by: 2026-12-31.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/com\.h2database/h2@.*$</packageUrl>
        <cve>CVE-0000-00000</cve>
    </suppress>

</suppressions>
