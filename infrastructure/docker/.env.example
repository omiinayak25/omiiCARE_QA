# =============================================================================
# omiiCARE Infrastructure — Environment Variable Defaults
# -----------------------------------------------------------------------------
# Copy this file to `.env` (same directory) and adjust values as needed:
#     cp .env.example .env
#
# IMPORTANT: `.env` is gitignored. NEVER commit real secrets. The values below
# are LOCAL DEVELOPMENT defaults only — replace them in any shared/CI setting.
# =============================================================================

# --- PostgreSQL --------------------------------------------------------------
POSTGRES_DB=omiicare
POSTGRES_USER=omiicare
POSTGRES_PASSWORD=omiicare
POSTGRES_PORT=5432

# --- Redis -------------------------------------------------------------------
REDIS_PORT=6379

# --- Mail (Mailpit / MailHog-compatible) -------------------------------------
MAIL_SMTP_PORT=1025
MAIL_UI_PORT=8025

# --- MinIO (S3-compatible object storage) ------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Keycloak (identity / OIDC) ----------------------------------------------
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_PORT=8081
KEYCLOAK_MGMT_PORT=9010

# --- WireMock (external system stubs) ----------------------------------------
WIREMOCK_PORT=8089

# --- Prometheus --------------------------------------------------------------
PROMETHEUS_PORT=9090

# --- Grafana -----------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_PORT=3000

# --- SonarQube ---------------------------------------------------------------
SONARQUBE_PORT=9002
