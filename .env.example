# =============================================================================
# omiiCARE_QA — root environment template.
# Copy to `.env` and adjust locally. NEVER commit a real `.env` (it is gitignored).
# Service-specific Docker values live in infrastructure/docker/.env.example.
# =============================================================================

# --- Active Spring profile: dev | local | docker | test | qa | stage | prod ---
SPRING_PROFILES_ACTIVE=dev

# --- Backend datasource (used by local/docker/qa/stage/prod profiles) ---
# dev/test use embedded H2 and ignore these.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=omiicare
DB_USERNAME=omiicare
DB_PASSWORD=omiicare
DB_POOL_SIZE=10

# --- Backend server ---
SERVER_PORT=8080

# --- Observability ---
MANAGEMENT_TRACING_SAMPLING_PROBABILITY=1.0

# --- JWT / security (wired in Milestone 3; placeholders only) ---
# Generate a strong secret for non-dev environments; never reuse this example value.
JWT_SECRET=change-me-in-every-real-environment
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7
