<?xml version="1.0" encoding="UTF-8"?>
<!--
  omiiCARE_QA SpotBugs exclusion filter.
  Consumed by: spotbugs-maven-plugin (excludeFilterFile).
  Run locally: mvn -pl apps/backend spotbugs:check
  Reference: https://spotbugs.readthedocs.io/en/latest/filter.html
-->
<FindBugsFilter
    xmlns="https://github.com/spotbugs/filter/3.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0 https://raw.githubusercontent.com/spotbugs/spotbugs/master/spotbugs/etc/findbugsfilter.xsd">

  <!-- Exclude generated code entirely -->
  <Match>
    <Source name="~.*[/\\]generated[/\\].*"/>
  </Match>
  <Match>
    <Class name="~.*MapperImpl"/>
  </Match>
  <Match>
    <Class name="~.*\.generated\..*"/>
  </Match>

  <!-- DTOs / entities legitimately expose internal representations.
       EI_EXPOSE_REP / EI_EXPOSE_REP2 are expected for value carriers. -->
  <Match>
    <Or>
      <Class name="~.*\.dto\..*"/>
      <Class name="~.*\.model\..*"/>
      <Class name="~.*\.entity\..*"/>
      <Class name="~.*Dto"/>
      <Class name="~.*Request"/>
      <Class name="~.*Response"/>
    </Or>
    <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
  </Match>

  <!-- Spring config / entity classes: serialization & field naming noise -->
  <Match>
    <Bug pattern="SE_BAD_FIELD,SE_NO_SERIALVERSIONID"/>
  </Match>

  <!-- Test code: relax a handful of common false positives -->
  <Match>
    <Source name="~.*[/\\]src[/\\]test[/\\].*"/>
    <Bug pattern="DLS_DEAD_LOCAL_STORE,RV_RETURN_VALUE_IGNORED_BAD_PRACTICE,NP_NONNULL_PARAM_VIOLATION"/>
  </Match>

  <!-- Lombok-generated equals/hashCode patterns -->
  <Match>
    <Bug pattern="EQ_DOESNT_OVERRIDE_EQUALS,HE_EQUALS_USE_HASHCODE"/>
  </Match>

</FindBugsFilter>
